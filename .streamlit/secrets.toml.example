# Streamlit Cloud の Settings > Secrets に以下を貼り付けてください
# ローカル開発時は .streamlit/secrets.toml にコピーして使用

password = "your-secure-password-here"

# ── プロファイル自動復元用（Streamlit Cloud再起動後に自動で設定される） ──
THREADS_ACCESS_TOKEN = ""
THREADS_USER_ID = ""
THREADS_APP_ID = ""
THREADS_APP_SECRET = ""
ANTHROPIC_API_KEY = ""
RESEARCH_KEYWORDS = "補助金,助成金,資金調達"
STYLE_GUIDE = ""
GENRE = "hojokin"
DISPLAY_NAME = "SNS HACK 補助金"
