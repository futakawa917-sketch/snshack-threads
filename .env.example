# Metricool API credentials
# Get your token from: Metricool Settings > API tab
METRICOOL_USER_TOKEN=your_api_token_here
METRICOOL_USER_ID=your_user_id_here
METRICOOL_BLOG_ID=your_blog_id_here

# Timezone (default: Asia/Tokyo)
METRICOOL_TIMEZONE=Asia/Tokyo

# Path to Threads analytics CSV export
# Each account should point to its own CSV file
THREADS_CSV_PATH=スレッズ.csv

# Threads Graph API (for competitor keyword search)
# Get token from: Meta Developer Console > Threads API
# Requires: threads_basic + threads_keyword_search (Advanced Access)
THREADS_ACCESS_TOKEN=your_threads_access_token_here

# Research keywords (comma-separated, same genre as your account)
RESEARCH_KEYWORDS=補助金,助成金,経営者,中小企業
